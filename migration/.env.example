# Copiază în `.env` (gitignored) și completează valorile reale.

# Connection string Neon (Dashboard -> Connection Details -> Pooled connection)
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Sursa datelor live. Alege UNA:
#  a) endpoint live (token real din admin -> Config)
SYNC_URL=https://cursurilapahar.ro/admin/sync-export.php?token=PUNE_TOKENUL_AICI
#  b) sau un fișier local deja descărcat (are prioritate dacă e setat)
# LIVE_FILE=./live.json
